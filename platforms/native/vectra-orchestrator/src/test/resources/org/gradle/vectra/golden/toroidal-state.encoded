# Toroidal golden payload encoded in source form (no binary artifact)
#
# Interlaced codec contract:
# - Uses VECTRA_LANES(32), VECTRA_PHASE_CYCLES(56), VECTRA_WEIGHTS(5), VECTRA_DIM(3), VECTRA_VERSION(2) as key material.
# - Even-index bytes belong to stream_a, odd-index bytes to stream_b.
# - Each stream byte is XOR-masked with a header-derived constant plus rolling index.
#
# This keeps fixture deterministic while avoiding checked-in binaries.
format=toroidal-interlaced-v1
payload_size=396
mask_a=0x1d
mask_b=0x5b
stream_
stream_
